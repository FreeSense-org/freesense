# Name of the product you are building. FreeSense is an Apache-2.0 community
# rebuild/rebrand of pfSense CE; build it under whatever name you like, but only
# repos signed with the FreeSense key (fingerprint shipped in the OS) are "official".
export PRODUCT_NAME="FreeSense"
# No edition suffix — one open-source edition (was "-CE").
export PRODUCT_NAME_SUFFIX=""
export PRODUCT_URL="https://freesense.org"
export PRODUCT_EMAIL="dev@freesense.local"
export FREEBSD_BRANCH="devel-main"
# Upstream FreeBSD ports uses 'main' (the old 'devel' was a pfSense-fork branch name;
# it does not exist in github.com/freebsd/freebsd-ports).
export POUDRIERE_PORTS_GIT_BRANCH="main"

# Repo signing: sign.sh shells out to openssl dgst -sign with this private key.
# In CI the key comes from the FREESENSE_REPO_SIGNING_KEY secret (written to a
# temp file); on the build VM it lives at /root/sign/repo.key.
export PKG_REPO_SIGNING_COMMAND="/root/sign/sign.sh /root/sign/repo.key"

# Build-host package deps: upstream list MINUS emulators/qemu-user-static (removed as a
# pkg on FreeBSD 16; only needed for cross-arch). Overrides the hard-coded list in
# builder_defaults.sh which is not otherwise overridable.
export BUILDER_PKG_DEPENDENCIES="devel/git ftp/curl net/rsync sysutils/screen sysutils/vmdktool security/sudo www/nginx archivers/gtar textproc/xmlstarlet"

# FreeBSD-src build config. devel-main split pfSense_src.conf into build_src.conf +
# install_src.conf; SRCCONF must point at our renamed build_src.conf inside the
# checked-out FreeBSD-src tree (under <repo>/tmp/FreeBSD-src, re-fetched each build).
# provision-buildhost.sh rewrites the leading path to match ${SRC_DIR}.
export SRCCONF="/root/freesense-src/tmp/FreeBSD-src/release/conf/FreeSense_build_src.conf"

# Kernel modules to build. Drops drm2 + ndis (removed in FreeBSD 16). Overridable because
# builder_defaults sets it only if unset.
export MODULES_OVERRIDE="cc/cc_cdg cc/cc_chd cc/cc_cubic cc/cc_dctcp cc/cc_hd cc/cc_htcp cc/cc_vegas cryptodev dummynet fdescfs hwpmc i2c if_stf ipdivert ipfw ipfw_nat64 opensolaris usb/cdce usb/ipheth usb/ure usb/urndis zfs aesni amdsmn amdtemp blake2 coretemp cpuctl cxgbe/tom ipmi ix ixv nmdm qlnx sfxge vmm"

# Core packages baked into the image (base system + kernel + factory config).
# FreeSense-repoc is our static repo client — it populates the System > Update
# branch selector and keeps each box's channel (devel/release) pinned.
export custom_package_list="FreeSense-base FreeSense-kernel-FreeSense FreeSense-default-config FreeSense-repoc"

# FreeBSD source repo: our org's fork of pfSense's FreeBSD-src (carries the kernel conf
# + bsdinstall customizations our confrename/installer-rebrand scripts expect; rebranded
# to FreeSense at build time). Set explicitly so it doesn't get derived from the repo
# remote (which would point at a nonexistent FreeSense-org/freebsd-src casing/path).
export FREEBSD_REPO_BASE="https://github.com/FreeSense-org/freebsd-src.git"
#export GIT_FREEBSD_COSHA1=##HASH##

# Do not clean FreeBSD obj dirs
#export NO_CLEAN_FREEBSD_OBJ=YES

# rsync data to upload snapshots
#export RSYNCIP="your.snapshot.server"
#export RSYNCUSER="username"
#export RSYNCPATH="/usr/local/www/snapshots"

# rsync data to upload pkg repo
#export PKG_RSYNC_HOSTNAME="pkg_repo_hostname"
#export PKG_RSYNC_USERNAME="username"
#export PKG_RSYNC_SSH_PORT="22"
#export PKG_RSYNC_DESTDIR="/usr/local/www/beta/packages"

# pkg repo URL — the self-hosted FreeSense repo (Cloudflare R2 static HTTPS).
# Both DEVEL and RELEASE point at the same repo; a -DEVELOPMENT build resolves the
# installed box's repo conf from _DEVEL (builder_common.sh gates on _IS_RELEASE).
# Plain https:// (NO 'pkg+' prefix): R2 is a single flat static bucket, so pkg must
# fetch <url>/meta.conf directly. The 'pkg+' scheme triggers mirror resolution (SRV
# DNS lookup) which R2 does not serve -> "pkg+:// implies SRV mirror type" errors.
export PKG_REPO_SERVER_DEVEL="https://pkg.freesense.org"
export PKG_REPO_SERVER_RELEASE="https://pkg.freesense.org"
#export PKG_REPO_SERVER_STAGING="pkg+http://release-staging.netgate.com/ce/packages"

# Branch to replace pkg.conf template, defaults to $GIT_REPO_BRANCH_OR_TAG
#export PKG_REPO_BRANCH_DEVEL="BRANCH"
#export PKG_REPO_BRANCH_RELEASE="BRANCH"
